SCOUT_AGENT_ID=
SCOUT_API_KEY=
SCOUT_HANDLE=

FORENSICS_AGENT_ID=
FORENSICS_API_KEY=
FORENSICS_HANDLE=

COMPLIANCE_AGENT_ID=
COMPLIANCE_API_KEY=
COMPLIANCE_HANDLE=

RISK_AGENT_ID=
RISK_API_KEY=
RISK_HANDLE=

SYNTHESIS_AGENT_ID=
SYNTHESIS_API_KEY=
SYNTHESIS_HANDLE=

GAP_AGENT_ID=
GAP_API_KEY=
GAP_HANDLE=

# --- LLM provider (OpenAI-compatible). Default = Groq (free, no card). ---
# Get a free key at https://console.groq.com . Works for all agents + scoring.
# To use another provider just change these (OpenRouter, Gemini OpenAI endpoint, AIML, etc.)
GROQ_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_MODEL_SMALL=llama-3.1-8b-instant
# Optional explicit override (else falls back to GROQ_API_KEY):
LLM_API_KEY=

# Legacy (no longer required; kept for reference):
# AIML_API_KEY=
# FEATHERLESS_API_KEY=

TAVILY_API_KEY=
EXA_API_KEY=

SENDGRID_API_KEY=
TWILIO_EMAIL_FROM=

# --- Google OAuth (login-only). If unset, auth is disabled (open for local dev). ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=https://srv-dev-01.tail599939.ts.net/auth/google/callback
# Optional comma-separated allowlist; empty = any Google account
ALLOWED_EMAILS=
# Where to send the user after login (the Vercel frontend URL)
FRONTEND_URL=
# Backend port (default 8000)
PORT=8000