# Band Agent Credentials — get these from app.band.ai/agents (New Agent → External Agent)
SCOUT_AGENT_ID=your-scout-agent-uuid
SCOUT_API_KEY=your-scout-api-key
SCOUT_HANDLE=@yourhandle/scout

FORENSICS_AGENT_ID=your-forensics-agent-uuid
FORENSICS_API_KEY=your-forensics-api-key
FORENSICS_HANDLE=@yourhandle/forensics

COMPLIANCE_AGENT_ID=your-compliance-agent-uuid
COMPLIANCE_API_KEY=your-compliance-api-key
COMPLIANCE_HANDLE=@yourhandle/compliance

RISK_AGENT_ID=your-risk-agent-uuid
RISK_API_KEY=your-risk-api-key
RISK_HANDLE=@yourhandle/risk

SYNTHESIS_AGENT_ID=your-synthesis-agent-uuid
SYNTHESIS_API_KEY=your-synthesis-api-key
SYNTHESIS_HANDLE=@yourhandle/synthesis

# LLM API Keys
AIML_API_KEY=your-aimlapi-key             # from aimlapi.com
FEATHERLESS_API_KEY=your-featherless-key  # from featherless.ai (promo: BOA26)

# Search API Keys (free tiers available)
TAVILY_API_KEY=your-tavily-key            # from tavily.com — 1000 free searches/month
EXA_API_KEY=your-exa-key                  # from exa.ai — free tier available
