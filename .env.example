# ─────────────────────────────────────────────────────────────────────────────
# LLM API KEYS
# ─────────────────────────────────────────────────────────────────────────────

# AI/ML API — used by Scout, Forensics, Compliance, Gap, Risk
# Sign up at aimlapi.com → Dashboard → API Keys
AIML_API_KEY=your-aimlapi-key

# Featherless AI — used by Synthesis (Qwen 72B)
# Sign up at featherless.ai — use promo code BOA26 for free credits
FEATHERLESS_API_KEY=your-featherless-key


# ─────────────────────────────────────────────────────────────────────────────
# SEARCH API KEYS
# ─────────────────────────────────────────────────────────────────────────────

# Tavily — web search (Scout: customer references, breach checks, news)
# Sign up at tavily.com — 1,000 free searches/month on free tier
TAVILY_API_KEY=your-tavily-key

# Exa — semantic/neural search (Scout: health system implementations)
# Sign up at exa.ai — free tier available
EXA_API_KEY=your-exa-key


# ─────────────────────────────────────────────────────────────────────────────
# BAND AGENT CREDENTIALS
# One agent_id + api_key pair per agent (6 total).
# Get these from: app.band.ai/agents → New Agent → External Agent
# Full setup instructions are in the README.
# ─────────────────────────────────────────────────────────────────────────────

# Agent 1: Scout
SCOUT_AGENT_ID=your-scout-agent-uuid
SCOUT_API_KEY=your-scout-api-key

# Agent 2: Forensics
FORENSICS_AGENT_ID=your-forensics-agent-uuid
FORENSICS_API_KEY=your-forensics-api-key

# Agent 3: Compliance
COMPLIANCE_AGENT_ID=your-compliance-agent-uuid
COMPLIANCE_API_KEY=your-compliance-api-key

# Agent 4: Gap
GAP_AGENT_ID=your-gap-agent-uuid
GAP_API_KEY=your-gap-api-key

# Agent 5: Risk
RISK_AGENT_ID=your-risk-agent-uuid
RISK_API_KEY=your-risk-api-key

# Agent 6: Synthesis
SYNTHESIS_AGENT_ID=your-synthesis-agent-uuid
SYNTHESIS_API_KEY=your-synthesis-api-key
