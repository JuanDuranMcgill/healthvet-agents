GAP_AGENT_ID=
GAP_API_KEY=
GAP_HANDLE=

# --- LLM providers (OpenAI-compatible) ---
# Agents run on AI/ML API; Synthesis + scoring run on Featherless.
# All endpoints/models are overridable (e.g. repoint to free Groq:
#   AIML_BASE_URL=https://api.groq.com/openai/v1, AIML_MODEL=llama-3.3-70b-versatile, etc.)
AIML_API_KEY=                       # from aimlapi.com (the 6 agents: gpt-4o / gpt-4o-mini)
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL=gpt-4o
AIML_MODEL_SMALL=gpt-4o-mini
FEATHERLESS_API_KEY=                 # from featherless.ai (Synthesis + scoring extractor)
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=Qwen/Qwen2.5-72B-Instruct

TAVILY_API_KEY=
EXA_API_KEY=

SENDGRID_API_KEY=
TWILIO_EMAIL_FROM=

# --- Google OAuth (login-only). If unset, auth is disabled (open for local dev). ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=https://srv-dev-01.tail599939.ts.net/auth/google/callback
# Optional comma-separated allowlist; empty = any Google account
ALLOWED_EMAILS=
# Comma-separated emails exempt from rate limits (e.g. the owner account)
UNLIMITED_EMAILS=
# Where to send the user after login (the Vercel frontend URL)
FRONTEND_URL=
# Backend port (default 8000)
PORT=8000