SCOUT_AGENT_ID=
SCOUT_API_KEY=
SCOUT_HANDLE=

FORENSICS_AGENT_ID=
FORENSICS_API_KEY=
FORENSICS_HANDLE=

COMPLIANCE_AGENT_ID=
COMPLIANCE_API_KEY=
COMPLIANCE_HANDLE=

RISK_AGENT_ID=
